// 键盘指南
"Setup" = "设置";
"In Any App" = "在任意 App 中";
"Style Buttons" = "风格按钮";
"Pair the Mac Server" = "配对 Mac 服务器";
"Paste the pairing JSON from the Mac app, then refresh Server Settings so iOS has the current languages and default mode." = "粘贴 Mac app 的配对 JSON,然后刷新服务器设置,让 iOS 获取当前语言和默认模式。";
"Enable the keyboard" = "启用键盘";
